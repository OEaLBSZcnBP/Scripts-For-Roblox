-- FE Invisible Script с локальной платформой и fake character (только для тебя)
-- Вставляй через executor (Synapse, Wave, Solara и т.д.)

local player = game.Players.LocalPlayer
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local isInvisible = false
local character = player.Character or player.CharacterAdded:Wait()

local screenGui = Instance.new("ScreenGui")
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 130, 0, 50)
button.Position = UDim2.new(0.5, -65, 0.85, -25)
button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.Text = "Invisible"
button.TextScaled = true
button.Font = Enum.Font.GothamBold
button.BorderSizePixel = 0
button.Parent = screenGui

-- Перетаскивание кнопки (оставил как было)
local dragging = false
local dragInput, dragStart, startPos

button.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = button.Position
	end
end)

button.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and (input == dragInput) then
		local delta = input.Position - dragStart
		button.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

-- Переменные для fake и платформы
local fakeCharacter = nil
local platform = nil
local originalHRP = nil

local function createPlatform()
	if platform then platform:Destroy() end
	platform = Instance.new("Part")
	platform.Size = Vector3.new(50, 2, 50)          -- большая платформа
	platform.Position = Vector3.new(0, 500, 0)      -- высоко в небе (можно поменять высоту)
	platform.Anchored = true
	platform.CanCollide = true
	platform.Transparency = 0.3
	platform.Color = Color3.fromRGB(30, 30, 30)
	platform.Parent = workspace
end

local function setInvisible(state)
	isInvisible = state
	
	if state then
		button.Text = "Visible"
		button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	else
		button.Text = "Invisible"
		button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	end
	
	if not character or not character:FindFirstChild("HumanoidRootPart") then return end
	
	-- Создаём/удаляем платформу
	if state then
		createPlatform()
		
		-- Клонируем персонажа (fake будет виден только тебе)
		character.Archivable = true
		fakeCharacter = character:Clone()
		character.Archivable = false
		
		-- Убираем скрипты из фейка, чтобы не было конфликтов
		for _, v in pairs(fakeCharacter:GetDescendants()) do
			if v:IsA("LocalScript") or v:IsA("Script") then
				v:Destroy()
			end
		end
		
		fakeCharacter.Parent = workspace
		fakeCharacter.HumanoidRootPart.CFrame = character.HumanoidRootPart.CFrame
		
		-- Делаем реальный персонаж "невидимым" для тебя и ставим его на платформу
		originalHRP = character.HumanoidRootPart.CFrame
		character.HumanoidRootPart.CFrame = platform.CFrame * CFrame.new(0, 5, 0)
		
		-- Делаем реальный персонаж полупрозрачным для тебя
		for _, part in pairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.LocalTransparencyModifier = 0.7
			end
		end
		
		-- Переключаем управление на fake
		player.Character = fakeCharacter
		workspace.CurrentCamera.CameraSubject = fakeCharacter.Humanoid
		
	else
		-- Возвращаем всё назад
		if fakeCharacter then
			fakeCharacter:Destroy()
			fakeCharacter = nil
		end
		
		if platform then
			platform:Destroy()
			platform = nil
		end
		
		if originalHRP then
			character.HumanoidRootPart.CFrame = originalHRP
		end
		
		player.Character = character
		workspace.CurrentCamera.CameraSubject = character.Humanoid
		
		-- Убираем прозрачность с реального персонажа
		for _, part in pairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				part.LocalTransparencyModifier = 0
			end
		end
	end
end

-- Клик по кнопке
button.MouseButton1Click:Connect(function()
	setInvisible(not isInvisible)
end)

-- Горячая клавиша Right Ctrl
UIS.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.RightControl then
		setInvisible(not isInvisible)
	end
end)

-- Обработка респавна
player.CharacterAdded:Connect(function(newChar)
	character = newChar
	task.wait(1)
	if isInvisible then
		-- При респавне выключаем режим, чтобы не было багов
		setInvisible(false)
	end
end)

print("Invisible script loaded с платформой в небе + fake character | Toggle: кнопка или Right Ctrl")
